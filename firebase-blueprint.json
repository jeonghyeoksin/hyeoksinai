{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "name": { "type": "string", "description": "Display name of the user." },
        "email": { "type": "string", "format": "email", "description": "Email address of the user." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role for access control." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Note": {
      "title": "Note",
      "description": "A note created by a user.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the note." },
        "content": { "type": "string", "description": "Body content of the note." },
        "authorId": { "type": "string", "description": "UID of the user who created the note." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the note was created." }
      },
      "required": ["title", "content", "authorId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "User notes."
    }
  }
}
